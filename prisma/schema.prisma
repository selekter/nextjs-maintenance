generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Truck {
  id                  BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  number_plate        String              @unique @db.VarChar(255)
  current_mileage     Int                 @default(0)
  driver_id           BigInt?             @db.UnsignedBigInt @unique
  created_at          DateTime?           @db.Timestamp(0) @default(now())
  updated_at          DateTime?           @updatedAt @db.Timestamp(0)
  drivers             Driver?             @relation(fields: [driver_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_license_plates_drivers")

  reports             Report[]
  maintenanceLogs     MaintenanceLog[]
  tireChangeHistories TireChangeHistory[]

  @@index([driver_id], map: "FK_license_plates_drivers")
  @@map("license_plates")
}

model Driver {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name       String    @db.VarChar(255) @unique
  created_at DateTime? @db.Timestamp(0) @default(now())
  updated_at DateTime? @updatedAt @db.Timestamp(0)
  trucks     Truck[]

  @@map("drivers")
}

model Report {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  license_plate_id BigInt    @db.UnsignedBigInt
  repair           String    @db.VarChar(255)
  status           Int       @default(0)
  description      String?   @db.Text
  created_at       DateTime? @default(now()) @db.Timestamp(0)
  updated_at       DateTime? @updatedAt @db.Timestamp(0)
  truck            Truck?    @relation(fields: [license_plate_id], references: [id])

  @@index([status, updated_at(sort: Desc)])
  @@index([license_plate_id], map: "report_repairs_license_plate_id_fkey")
  @@map("report_repairs")
}

model migrations {
  id        Int    @id @default(autoincrement()) @db.UnsignedInt
  migration String @db.VarChar(255)
  batch     Int
}

model password_reset_tokens {
  email      String    @id @db.VarChar(255)
  token      String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0) @default(now())
}

model personal_access_tokens {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  tokenable_type String    @db.VarChar(255)
  tokenable_id   BigInt    @db.UnsignedBigInt
  name           String    @db.VarChar(255)
  token          String    @unique(map: "personal_access_tokens_token_unique") @db.VarChar(64)
  abilities      String?   @db.Text
  last_used_at   DateTime? @db.Timestamp(0)
  expires_at     DateTime? @db.Timestamp(0)
  created_at     DateTime? @db.Timestamp(0) @default(now())
  updated_at     DateTime? @db.Timestamp(0) @updatedAt

  @@index([tokenable_type, tokenable_id], map: "personal_access_tokens_tokenable_type_tokenable_id_index")
}

model users {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name              String    @db.VarChar(255)
  email             String    @unique(map: "users_email_unique") @db.VarChar(255)
  email_verified_at DateTime? @db.Timestamp(0)
  password          String    @db.VarChar(255)
  remember_token    String?   @db.VarChar(100)
  created_at        DateTime? @db.Timestamp(0) @default(now())
  updated_at        DateTime? @db.Timestamp(0) @updatedAt
}

model MaintenanceLog {
  id              BigInt   @id @default(autoincrement())
  truck_id        BigInt   @db.UnsignedBigInt
  type            String
  service_mileage Int
  next_service_at Int
  description     String?
  created_at      DateTime @default(now())

  truck Truck @relation(fields: [truck_id], references: [id])

  @@index([truck_id, created_at])
}

model TireChangeHistory {
  id                BigInt     @id @default(autoincrement())
  truck_id          BigInt     @db.UnsignedBigInt
  change_date       DateTime   @default(now())
  mileage_at_change Int
  notes             String?    @db.Text
  truck             Truck      @relation(fields: [truck_id], references: [id])
  tireItems         TireItem[]

  @@index([truck_id])
  @@map("tire_change_history")
}

model TireBrand {
  id    Int        @id @default(autoincrement())
  name  String     @unique
  items TireItem[]

  @@map("tire_brand")
}

model TireItem {
  id             BigInt @id @default(autoincrement())
  tire_change_id BigInt
  brand_id       Int
  tire_code      String
  position       Int

  brand   TireBrand         @relation(fields: [brand_id], references: [id])
  history TireChangeHistory @relation(fields: [tire_change_id], references: [id])

  @@index([tire_change_id])
  @@map("tire_item")
}
