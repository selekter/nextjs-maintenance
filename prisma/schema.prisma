generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Truck {
  id                  BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  number_plate        String              @unique @db.VarChar(255)
  current_mileage     Int                 @default(0)
  driver_id           BigInt?             @unique @db.UnsignedBigInt
  created_at          DateTime?           @default(now()) @db.Timestamp(0)
  updated_at          DateTime?           @updatedAt @db.Timestamp(0)
  drivers             Driver?             @relation(fields: [driver_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_license_plates_drivers")
  maintenancelog      maintenancelog[]
  reports             Report[]
  tireChangeHistories TireChangeHistory[]

  @@index([driver_id], map: "FK_license_plates_drivers")
  @@map("license_plates")
}

model Driver {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name       String    @unique @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @updatedAt @db.Timestamp(0)
  trucks     Truck?

  @@map("drivers")
}

model Report {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  license_plate_id BigInt    @db.UnsignedBigInt
  repair           String    @db.VarChar(255)
  status           Int       @default(0)
  description      String?   @db.Text
  created_at       DateTime? @default(now()) @db.Timestamp(0)
  updated_at       DateTime? @updatedAt @db.Timestamp(0)
  truck            Truck     @relation(fields: [license_plate_id], references: [id])

  @@index([status, updated_at(sort: Desc)])
  @@index([license_plate_id], map: "report_repairs_license_plate_id_fkey")
  @@map("report_repairs")
}

model TireChangeHistory {
  id                BigInt     @id @default(autoincrement())
  truck_id          BigInt     @db.UnsignedBigInt
  change_date       DateTime   @default(now())
  mileage_at_change Int
  notes             String?    @db.Text
  truck             Truck      @relation(fields: [truck_id], references: [id])
  tireItems         TireItem[]

  @@index([truck_id])
  @@map("tire_change_history")
}

model TireBrand {
  id    Int        @id @default(autoincrement())
  name  String     @unique
  items TireItem[]

  @@map("tire_brand")
}

model TireItem {
  id             BigInt            @id @default(autoincrement())
  tire_change_id BigInt
  brand_id       Int
  tire_code      String
  position       Int
  brand          TireBrand         @relation(fields: [brand_id], references: [id])
  history        TireChangeHistory @relation(fields: [tire_change_id], references: [id])

  @@index([tire_change_id])
  @@index([brand_id], map: "tire_item_brand_id_fkey")
  @@map("tire_item")
}

model maintenancelog {
  id              BigInt   @id @default(autoincrement())
  truck_id        BigInt   @db.UnsignedBigInt
  type            String
  service_mileage Int
  next_service_at Int
  description     String?
  created_at      DateTime @default(now())
  license_plates  Truck    @relation(fields: [truck_id], references: [id], map: "MaintenanceLog_truck_id_fkey")

  @@index([truck_id, created_at], map: "MaintenanceLog_truck_id_created_at_idx")
}

model User {
  id            String    @id
  name          String    @db.Text
  email         String
  emailVerified Boolean   @default(false)
  image         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.Text
  userAgent String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId(length: 191)])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId(length: 191)])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier(length: 191)])
  @@map("verification")
}
